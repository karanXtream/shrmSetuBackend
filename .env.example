# Service Marketplace Backend - Environment Variables
# Copy this file to .env and fill in your actual values

# Environment
NODE_ENV=development
PORT=5000

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/shrm-setu
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/shrm-setu

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# JWT Configuration (for future authentication)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Email Configuration (for future OTP/email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
